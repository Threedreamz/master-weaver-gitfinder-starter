# =============================================================================
# GitFinder Starter — Environment Variables
# =============================================================================
# Copy to .env.local:  cp .env.example .env.local

# App Ports
PORT=4630
API_PORT=4631
WORKER_PORT=4632
NODE_ENV=development

# Auth (FinderAuth OIDC)
# Apps work without auth by default (mock mode for local dev).
FINDERAUTH_ISSUER=https://auth.finderfinder.org/oidc
FINDERAUTH_CLIENT_ID=gitfinder-hub
FINDERAUTH_CLIENT_SECRET=

# Auth session secret — generate with: openssl rand -base64 48
AUTH_SECRET=

# Full public URL of the hub (required for NextAuth v5 in production)
# AUTH_URL=https://gitfinder-hub-dev.up.railway.app

# Database
# Local SQLite (default for dev)
DATABASE_URL=file:./gitfinder.db
# Production PostgreSQL (Railway injects this automatically)
# DATABASE_URL=postgresql://user:pass@host:5432/gitfinder

# GitFinder API URL (used by hub)
GITFINDER_API_URL=http://localhost:4631

# DevTools Integration (optional)
DEVTOOLS_URL=http://localhost:4050
DEVTOOLS_SECRET=

# Railway (production — set as Railway env vars)
# HOSTNAME=0.0.0.0
